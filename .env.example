# GitHub — crie em: https://github.com/settings/tokens
# Escopos necessários: repo, read:org, read:user
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# PostgreSQL — formato: postgresql://user:senha@host:5432/driveos
POSTGRES_CONNECTION_STRING=postgresql://postgres:senha@localhost:5432/driveos

# Notion — crie em: https://www.notion.so/profile/integrations
# Tipo: Internal integration token
NOTION_API_KEY=ntn_...

# ── Monorepo (adicionado pelo scaffold) ──────────────────────────────────────
# LGPD: estas chaves têm acesso a dados pessoais — nunca commitar valores reais

# API (apps/api) — acesso ao banco com dados de usuário e localização
DATABASE_URL=postgresql://postgres:senha@localhost:5432/driveos
PORT=3001

# IA — não enviar PII diretamente para o modelo; usar apenas dados anonimizados
ANTHROPIC_API_KEY=sk-ant-...

# Web (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Mobile (apps/mobile)
EXPO_PUBLIC_API_URL=http://localhost:3001
